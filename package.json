{
  "name": "irishpeptides-jarvis",
  "version": "1.0.0",
  "description": "Irish Peptides Jarvis — Desktop Command Centre",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.irishpeptides.jarvis",
    "productName": "Irish Peptides Jarvis",
    "copyright": "Copyright 2026 Irish Peptides & Nutrition",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Irish Peptides Jarvis"
    },
    "afterAllArtifactBuild": "scripts/after-build.js"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
